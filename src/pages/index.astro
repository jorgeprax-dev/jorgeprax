---
import Layout from '../layouts/Layout.astro';

const formacion = [
  { company: 'ITESM', role: 'Ingeniería Industrial' },
  { company: 'Carnegie Mellon University', role: 'MSc in Information Systems Management' },
  { company: 'ITESM', role: 'MSc in Management of IT' },
];

const experiencia = [
  { company: 'London Consulting Group · 6 años', role: 'Director de Business Intelligence · Transformación operativa en LATAM, EE.UU. y Canadá · +$25M USD en mejoras documentadas' },
  { company: 'Microsoft Azure', role: 'Supply Chain y analítica aplicada a operaciones industriales' },
  { company: 'Accenture', role: 'Integración de adquisiciones · Due diligence operativo' },
  { company: 'Elanboard · Fundador', role: 'ERP / SAP B1 para empresas manufactureras en México' },
];

const proyectosLargos = [
  { name: 'Sintelo', url: 'https://sintelo.com', urlLabel: 'sintelo.com →', desc: 'Capital allocation advisory para empresas industriales. ROIC, capital de trabajo, due diligence operacional.' },
  { name: 'Lucidez', url: 'https://lucidez.app', urlLabel: 'lucidez.app →', desc: 'Plataforma de autoconocimiento con IA en español. Seis instrumentos psicométricos validados.' },
];

const fallback = {
  Substack: [{ title: 'El vacío no es ausencia: es desestructuración', link: 'https://substack.com/@jorgeprax', pubDate: '2026-04-09' }],
  Sintelo: [
    { title: 'Por qué su empresa tiene buen EBITDA pero poco efectivo', link: 'https://sintelo.com/blog/ebitda-efectivo', pubDate: '2025-03-12' },
    { title: 'Cómo calcular el ROIC de su empresa en una tarde', link: 'https://sintelo.com/blog/calcular-roic', pubDate: '2025-02-28' },
    { title: 'El error más común al hacer due diligence en México', link: 'https://sintelo.com/blog/due-diligence-mexico', pubDate: '2025-02-10' },
  ],
};

const formatDate = (d) => new Date(d).toLocaleDateString('es-MX', { month: 'long', year: 'numeric' });

const contactos = [
  { label: 'jorge@sintelo.com', href: 'mailto:jorge@sintelo.com' },
  { label: 'GitHub · jorgeprax81', href: 'https://github.com/jorgeprax81' },
  { label: 'GitHub · jorgeprax-dev', href: 'https://github.com/jorgeprax-dev' },
  { label: 'Substack', href: 'https://substack.com/@jorgeprax' },
];
---

<Layout>
  <div class="page">

    <div class="avatar">JP</div>
    <div class="eyebrow">Tampico, México</div>
    <div class="name">Jorge Prax</div>

    <p class="bio">Construyo herramientas que hacen visible lo que normalmente permanece oculto.</p>

    <div class="info-grid">
      <div>
        <div class="source-label first">Proyectos</div>
        <div class="info-block-mt">
          <div class="proj-mini-name">Sintelo</div>
          <div class="proj-mini-desc">Capital allocation advisory para empresas industriales en México. ROIC, capital de trabajo, due diligence operacional.</div>
          <div class="proj-mini-name">Lucidez</div>
          <div class="proj-mini-desc-last">Plataforma de autoconocimiento con IA en español. Seis instrumentos psicométricos validados.</div>

          <div class="stack-wrap">
            <div class="stack-label">Stack</div>
            <div class="stack-list">
              Python · SQL<br />
              JavaScript · React<br />
              Astro · Jupyter
            </div>
          </div>
        </div>
      </div>

      <div>
        <div class="source-label first">Formación</div>
        <div class="info-block-mt">
          {formacion.map((e) => (
            <div class="info-item">
              <div class="info-company">{e.company}</div>
              <div class="info-role">{e.role}</div>
            </div>
          ))}
        </div>

        <div class="source-label">Experiencia</div>
        <div class="info-block-mt">
          {experiencia.map((e, i) => (
            <div class={`info-item ${i === experiencia.length - 1 ? 'last' : ''}`}>
              <div class="info-company">{e.company}</div>
              <div class="info-role">{e.role}</div>
            </div>
          ))}
        </div>
      </div>
    </div>

    <div class="divider"></div>
    <span class="label">Proyectos</span>

    {proyectosLargos.map((p) => (
      <a href={p.url} target="_blank" rel="noopener noreferrer" class="project-link">
        <div class="project-row">
          <span class="project-name">{p.name}</span>
          <span class="project-url">{p.urlLabel}</span>
        </div>
        <p class="project-desc">{p.desc}</p>
      </a>
    ))}

    <div class="divider"></div>
    <span class="label">Escritura</span>

    <div id="writing-content">
      {Object.entries(fallback).map(([source, posts]) => (
        <div class="writing-block">
          <div class="source-label-writing">{source}</div>
          {posts.map((post) => (
            <a href={post.link} target="_blank" rel="noopener noreferrer" class="article-row">
              <span class="article-title">{post.title}</span>
              <span class="article-date">{formatDate(post.pubDate)}</span>
            </a>
          ))}
        </div>
      ))}
    </div>

    <div class="divider"></div>
    <span class="label">Contacto</span>
    <div class="link-row">
      {contactos.map((l) => (
        <a href={l.href} target="_blank" rel="noopener noreferrer" class="link">{l.label}</a>
      ))}
    </div>

    <div class="footer">Tampico, México · 2026</div>

  </div>
</Layout>

<style>
  .page {
    max-width: 800px;
    margin: 0 auto;
    padding: 80px 32px 120px;
  }

  .avatar {
    width: 72px;
    height: 72px;
    border-radius: 50%;
    background: var(--accent-dim);
    border: 0.5px solid var(--accent-border);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--serif);
    font-size: 24px;
    color: var(--accent);
    margin-bottom: 2rem;
  }

  .eyebrow {
    font-family: var(--sans);
    font-size: 11px;
    letter-spacing: 0.2em;
    color: var(--accent);
    text-transform: uppercase;
    margin-bottom: 2rem;
  }

  .name {
    font-family: var(--serif);
    font-size: clamp(48px, 7vw, 72px);
    font-weight: 400;
    color: #F0EBE0;
    line-height: 1.05;
    letter-spacing: -0.01em;
    margin-bottom: 2rem;
  }

  .bio {
    font-size: 16px;
    color: var(--muted);
    line-height: 1.9;
    margin-bottom: 1rem;
    font-weight: 300;
  }

  /* INFO GRID */
  .info-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    margin-top: 3rem;
  }

  .source-label {
    font-family: var(--sans);
    font-size: 11px;
    letter-spacing: 0.15em;
    color: var(--dim);
    text-transform: uppercase;
    margin-bottom: 0;
    margin-top: 2rem;
  }

  .source-label.first {
    margin-top: 0;
  }

  .info-block-mt {
    margin-top: 1.5rem;
  }

  /* AJUSTE 1: Más respiración entre nombre azul y descripción gris */
  .proj-mini-name {
    font-size: 14px;
    color: var(--accent);
    margin-bottom: 0.5rem;
  }

  .proj-mini-desc {
    font-size: 13px;
    color: var(--dim);
    line-height: 1.7;
    margin-bottom: 1.5rem;
  }

  .proj-mini-desc-last {
    font-size: 13px;
    color: var(--dim);
    line-height: 1.7;
  }

  .stack-wrap {
    margin-top: 2.5rem;
  }

  .stack-label {
    font-size: 11px;
    letter-spacing: 0.15em;
    color: var(--dim);
    text-transform: uppercase;
    margin-bottom: 1rem;
  }

  .stack-list {
    font-size: 13px;
    color: var(--dim);
    line-height: 2;
  }

  /* AJUSTE 2: Más respiración entre nombre azul y rol gris en formación/experiencia */
  .info-item {
    padding-bottom: 1.1rem;
    margin-bottom: 1.1rem;
    border-bottom: 0.5px solid var(--border);
  }

  .info-item.last {
    border-bottom: none;
  }

  .info-company {
    font-size: 13px;
    color: var(--accent);
    margin-bottom: 0.5rem;
  }

  .info-role {
    font-size: 13px;
    color: var(--dim);
    line-height: 1.6;
  }

  .divider {
    height: 0.5px;
    background: var(--border);
    margin: 5rem 0;
  }

  .label {
    font-family: var(--sans);
    font-size: 11px;
    letter-spacing: 0.2em;
    color: var(--accent);
    text-transform: uppercase;
    margin-bottom: 2rem;
    display: block;
  }

  .project-link {
    display: block;
    text-decoration: none;
  }

  .project-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: 1.5rem 0;
    border-bottom: 0.5px solid var(--border);
  }

  .project-name {
    font-family: var(--serif);
    font-size: 24px;
    color: #F0EBE0;
  }

  .project-url {
    font-size: 12px;
    color: var(--accent);
    letter-spacing: 0.04em;
  }

  .project-desc {
    font-size: 13px;
    color: var(--dim);
    margin-top: 0.5rem;
    line-height: 1.8;
  }

  /* AJUSTE 3: Espacio entre bloques de fuente en Escritura */
  .writing-block {
    margin-bottom: 3rem;
  }

  .writing-block:last-child {
    margin-bottom: 0;
  }

  /* AJUSTE 4: source-label de Escritura con más respiración hacia los artículos */
  .source-label-writing {
    font-family: var(--sans);
    font-size: 11px;
    letter-spacing: 0.15em;
    color: var(--dim);
    text-transform: uppercase;
    margin-bottom: 1.25rem;
  }

  .article-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 2rem;
    padding: 1rem 0;
    border-bottom: 0.5px solid rgba(255, 255, 255, 0.04);
    text-decoration: none;
  }

  .article-title {
    font-family: var(--serif);
    font-size: 20px;
    color: #E8E3D8;
    line-height: 1.3;
  }

  .article-date {
    font-size: 12px;
    color: var(--dim);
    white-space: nowrap;
  }

  .link-row {
    display: flex;
    gap: 2rem;
    flex-wrap: wrap;
    margin-top: 1rem;
  }

  .link {
    font-size: 14px;
    color: var(--muted);
    border-bottom: 0.5px solid rgba(138, 132, 122, 0.3);
    padding-bottom: 1px;
  }

  .footer {
    font-size: 12px;
    color: #3A3430;
    margin-top: 5rem;
  }

  /* MOBILE */
  @media (max-width: 720px) {
    .page {
      padding: 60px 24px 80px;
    }

    .divider {
      margin: 3.5rem 0;
    }

    .info-grid {
      grid-template-columns: 1fr;
      gap: 3rem;
      margin-top: 2.5rem;
    }

    .article-row {
      flex-direction: column;
      gap: 0.4rem;
      align-items: flex-start;
    }

    .article-title {
      font-size: 18px;
    }

    .project-row {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.4rem;
    }

    .link-row {
      flex-direction: column;
      gap: 1rem;
    }
  }
</style>

<script>
  const API_KEY = 'yci5czemsofiibxgualdvxcungznkln3ppuvbga4';

  async function fetchFeed(url, source) {
    try {
      const r = await fetch(`https://api.rss2json.com/v1/api.json?rss_url=${encodeURIComponent(url)}&api_key=${API_KEY}&count=3`);
      const d = await r.json();
      return (d.items || []).slice(0, 3).map((p) => ({ ...p, source }));
    } catch {
      return [];
    }
  }

  function formatDate(dateStr) {
    return new Date(dateStr).toLocaleDateString('es-MX', { month: 'long', year: 'numeric' });
  }

  async function loadFeeds() {
    const [substack, sintelo] = await Promise.all([
      fetchFeed('https://jorgeprax.substack.com/feed', 'Substack'),
      fetchFeed('https://sintelo.com/rss.xml', 'Sintelo'),
    ]);

    if (substack.length === 0 && sintelo.length === 0) return;

    const container = document.getElementById('writing-content');
    if (!container) return;

    container.innerHTML = '';

    for (const source of ['Substack', 'Sintelo']) {
      const posts = source === 'Substack' ? substack : sintelo;
      if (posts.length === 0) continue;

      const block = document.createElement('div');
      block.style.cssText = 'margin-bottom:3rem;';

      const label = document.createElement('div');
      label.style.cssText = "font-family:'DM Sans',sans-serif;font-size:11px;letter-spacing:0.15em;color:#888480;text-transform:uppercase;margin-bottom:1.25rem;display:block;";
      label.textContent = source;
      block.appendChild(label);

      for (const post of posts) {
        const row = document.createElement('a');
        row.href = post.link || post.url;
        row.target = '_blank';
        row.rel = 'noopener noreferrer';
        row.style.cssText = 'display:flex;justify-content:space-between;align-items:baseline;gap:2rem;padding:1rem 0;border-bottom:0.5px solid rgba(255,255,255,0.04);text-decoration:none;';

        const title = document.createElement('span');
        title.style.cssText = "font-family:'Cormorant Garamond',Georgia,serif;font-size:20px;color:#E8E3D8;line-height:1.3;";
        title.textContent = post.title;
        row.appendChild(title);

        const date = document.createElement('span');
        date.style.cssText = 'font-size:12px;color:#888480;white-space:nowrap;';
        date.textContent = formatDate(post.pubDate);
        row.appendChild(date);

        block.appendChild(row);
      }

      container.appendChild(block);
    }
  }

  loadFeeds();
</script>
